{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/join/:code", "destination": "/join" },
    { "source": "/g/:code", "destination": "/join" },
    { "source": "/invite/:code", "destination": "/join" }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
